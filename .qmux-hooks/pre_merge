#!/bin/bash
# Example: pre_merge hook
#
# Runs safety checks before merge. Non-zero exit aborts merge.

set -euo pipefail

echo "[Hook] Running pre-merge checks for $QMUX_SLUG"

cd "$QMUX_WORKTREE_PATH"

if [ "${QMUX_SKIP_PRE_MERGE:-0}" = "1" ]; then
  echo "[Hook] QMUX_SKIP_PRE_MERGE=1, skipping checks"
  exit 0
fi

pnpm run typecheck
pnpm run test

echo "[Hook] Pre-merge checks passed"
